(function() {
  const stickyBar = document.getElementById('StickyATC');
  const stickyBtn = document.getElementById('StickyATCBtn');
  const mainAtc = document.querySelector('.product-add-to-cart');

  if (!stickyBar || !stickyBtn || !mainAtc) return;

  // Show/hide based on scroll position of main ATC button
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        stickyBar.classList.add('translate-y-full');
        document.body.classList.remove('sticky-atc-active');
      } else {
        stickyBar.classList.remove('translate-y-full');
        document.body.classList.add('sticky-atc-active');
      }
    });
  }, { threshold: 0.1 });

  observer.observe(mainAtc);

  // Proxy click to the main ATC button
  stickyBtn.addEventListener('click', () => {
    mainAtc.click();
  });

  // Mirror disabled state from main ATC
  const mirrorState = () => {
    stickyBtn.disabled = mainAtc.disabled;
    const btnText = mainAtc.querySelector('.btn-text');
    if (btnText) stickyBtn.textContent = btnText.textContent;
    if (mainAtc.style.backgroundColor) {
      stickyBtn.style.backgroundColor = mainAtc.style.backgroundColor;
    } else {
      stickyBtn.style.backgroundColor = '#006039';
    }
  };

  new MutationObserver(mirrorState).observe(mainAtc, { attributes: true, subtree: true, childList: true });
  mirrorState();
})();
</script>
{%- endif -%}
{%- endunless -%}

  <!-- Size Chart Sub-Modal -->
  {%- if size_chart_html != blank -%}
    <div
      class="product-size-chart-modal hidden fixed inset-0 z-[99999] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
    >
      <div
