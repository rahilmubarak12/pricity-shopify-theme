{% comment %}
  Product Detail Snippet
  Shared code for both main-product.liquid section and templates/product.quickview.liquid.
  Accepts:
  - product: {Product} Shopify product object
  - is_modal: {Boolean} true if rendered inside the quickview modal
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign images = product.images
  assign featured_image = current_variant.featured_image | default: product.featured_image

  assign is_out_of_stock = true
  if product.available
    assign is_out_of_stock = false
  endif

  # Calculate discounts
  assign is_on_sale = false
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  if compare_at_price > price
    assign is_on_sale = true
  endif

  # Select size chart based on product title + type keywords
  assign product_title_lower = product.title | downcase
  assign product_type_lower = product.type | downcase
  assign combined_text = product_title_lower | append: ' ' | append: product_type_lower
  assign size_chart_title = 'Size Chart'
  assign size_chart_key = 'default'

  if combined_text contains 'yellow' or combined_text contains 'pink top'
    assign size_chart_key = 'none'
  elsif combined_text contains 'a new era' and combined_text contains 'crop'
    assign size_chart_key = 'a-new-era-cropped'
    assign size_chart_title = 'A New Era Cropped Sweatshirt Size Chart'
  elsif combined_text contains 'turtleneck'
    assign size_chart_key = 'turtleneck'
    assign size_chart_title = 'Oversized Sweatshirt Turtleneck Size Chart'
  elsif combined_text contains 'double collar' and combined_text contains 'crop'
    assign size_chart_key = 'women-cropped'
    assign size_chart_title = 'Double Collar Cropped Sweatshirt Size Chart'
  elsif combined_text contains 'hoodie'
    assign size_chart_key = 'hoodie'
    assign size_chart_title = 'Unisex Hoodies Size Chart'
  elsif combined_text contains 'staple' or combined_text contains 'sand'
    assign size_chart_key = 'staple'
    assign size_chart_title = 'Staple Sand Unisex Size Chart'
  elsif combined_text contains 'linen'
    assign size_chart_key = 'linen'
    assign size_chart_title = 'Linen Shirt & Shorts Size Chart'
  elsif combined_text contains 't-shirt' or combined_text contains 'tshirt' or combined_text contains 't shirt' or combined_text contains 'tee' or combined_text contains 'top'
    assign size_chart_key = 'tshirt'
    assign size_chart_title = 'Unisex T-Shirt Size Chart'
  elsif combined_text contains 'set'
    assign size_chart_key = 'linen'
    assign size_chart_title = 'Linen Shirt & Shorts Size Chart'
  elsif combined_text contains 'crop'
    assign size_chart_key = 'women-cropped'
    assign size_chart_title = 'Double Collar Cropped Sweatshirt Size Chart'
  elsif combined_text contains 'sweatshirt' or combined_text contains 'sweater'
    assign size_chart_key = 'sweatshirt'
    assign size_chart_title = 'Unisex Sweatshirts Size Chart'
  else
    assign size_chart_key = 'sweatshirt'
    assign size_chart_title = 'Unisex Sweatshirts Size Chart'
  endif

  if product.handle == 'apricity-blush' or product.handle == 'apy-butter-set'
    assign size_chart_key = 'none'
  endif
-%}

{% capture size_chart_html %}
  {% case size_chart_key %}
    {% when 'turtleneck' %}
      {{ settings.size_chart_turtleneck }}
    {% when 'women-cropped' %}
      {{ settings.size_chart_cropped }}
    {% when 'a-new-era-cropped' %}
      {{ settings.size_chart_a_new_era }}
    {% when 'hoodie' %}
      {{ settings.size_chart_hoodie }}
    {% when 'tshirt' %}
      {{ settings.size_chart_tshirt }}
    {% when 'linen' %}
      {{ settings.size_chart_linen }}
    {% when 'staple' %}
      {{ settings.size_chart_staple }}
    {% when 'none' %}
      {%- comment -%} Explicitly return empty chart {%- endcomment -%}
    {% else %}
      {{ settings.size_chart_default }}
  {% endcase %}
{% endcapture %}
{%- assign size_chart_html = size_chart_html | strip -%}

{%- comment -%} If key is 'none', clear the chart {%- endcomment -%}
{%- if size_chart_key == 'none' -%}
  {%- assign size_chart_html = '' -%}
{%- endif -%}

{%- comment -%} Metafield override: if custom.size_chart is set, use it instead {%- endcomment -%}
{%- if product.metafields.custom.size_chart != blank -%}
  {%- assign size_chart_html = product.metafields.custom.size_chart.value -%}
  {%- assign size_chart_title = 'Size Chart' -%}
{%- endif -%}

<div class="product-detail-wrapper flex flex-col lg:flex-row w-full h-full" data-product-handle="{{ product.handle }}">
  
  <!-- LEFT COLUMN: Image Gallery -->
  <div class="product-detail-gallery w-full lg:w-1/2 bg-zinc-50 p-6 flex flex-col gap-3 lg:h-full lg:overflow-y-auto" style="-webkit-overflow-scrolling: touch;">
    <div class="w-full bg-white rounded-2xl overflow-hidden relative">
      <img 
        src="{{ featured_image | image_url: width: 1000 }}" 
        alt="{{ product.title | escape }}" 
        class="product-main-image w-full h-auto object-contain transition-transform duration-700 ease-out hover:scale-110 cursor-zoom-in"
       width="1000" height="1000" />
    </div>
    {%- if images.size > 1 -%}
      <div class="flex gap-2 overflow-x-auto pb-1 product-thumbnails">
        {%- for img in images -%}
          <button
            type="button"
            class="thumbnail-btn flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 transition {% if featured_image == img %}border-black{% else %}border-transparent{% endif %}"
            data-image-url="{{ img | image_url: width: 1000 }}"
          >
            <img src="{{ img | image_url: width: 150 }}" alt="" class="w-full h-full object-cover"  width="1000" height="1000" />
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- RIGHT COLUMN: Details & Option Pickers -->
  <div class="product-detail-info w-full lg:w-1/2 flex flex-col lg:h-full lg:overflow-hidden bg-white">
    <!-- Scrollable Panel -->
    <div class="product-detail-scrollable flex-1 lg:overflow-y-auto px-8 py-10 gap-6 flex flex-col" style="-webkit-overflow-scrolling: touch;">
      
      <!-- Title & Price -->
      <div class="flex flex-col gap-2">
        <h2 class="text-2xl font-bold uppercase leading-tight tracking-tight text-[#1a1a1a]">
          {{ product.title }}
        </h2>
        <div class="flex items-baseline gap-3">
          <span class="product-price-display text-2xl font-semibold tracking-tight text-zinc-900">
            {{ price | money_without_trailing_zeros }}
          </span>
          <span class="product-compare-display text-sm text-zinc-400 line-through {% unless is_on_sale %}hidden{% endunless %}">
            {{ compare_at_price | money_without_trailing_zeros }}
          </span>
        </div>
      </div>

      <!-- Option Selectors -->
      {%- unless product.has_only_default_variant -%}
        <div class="product-options-picker space-y-6">
          {%- for option in product.options_with_values -%}
            {%- assign option_name_lower = option.name | downcase -%}
            
            {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
              {%- assign color_option_index = forloop.index0 -%}
              <!-- Color Selector -->
              <div class="option-color-container" data-option-index="{{ color_option_index }}">
                <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 mb-3 font-medium">
                  Colour — <span class="active-color-label text-zinc-600 normal-case tracking-normal">{{ option.selected_value }}</span>
                </p>
                <div class="flex flex-wrap gap-2">
                  {%- for value in option.values -%}
                    {%- liquid
                      # Simple color verification to see if at least one variant of this color is in stock
                      assign color_in_stock = false
                      for variant in product.variants
                        if variant.options[color_option_index] == value and variant.available
                          assign color_in_stock = true
                        endif
                      endfor
                    -%}
                    <button
                      type="button"
                      class="color-option-btn px-4 py-2 text-xs rounded-full border transition-all duration-200 tracking-wide {% if option.selected_value == value %}bg-zinc-900 text-white border-zinc-900 shadow-md{% else %}bg-white text-zinc-700 border-zinc-200 hover:border-zinc-500{% endif %} {% unless color_in_stock %}opacity-35 line-through{% endunless %}"
                      data-value="{{ value }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>

            {%- elsif option_name_lower == 'size' or option_name_lower == 'sizes' or option_name_lower contains 'size' -%}
              {%- assign size_option_index = forloop.index0 -%}
              <!-- Size Selector -->
              <div class="option-size-container rounded-2xl border border-zinc-100 bg-zinc-50/80 p-5" data-option-index="{{ size_option_index }}">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-medium">
                    Select Size
                  </span>
                  
                  <!-- Live Stock Message (amber dots/critical alerts) -->
                  <span class="stock-status-indicator text-[10px] font-semibold tracking-wide uppercase flex items-center gap-1.5 text-emerald-600">
                    <!-- Updated by JS -->
                    In Stock
                  </span>
                </div>

                <div class="grid grid-cols-4 gap-2">
                  {%- for value in option.values -%}
                    {%- liquid
                      # Check if this size is available
                      assign size_variant = nil
                      for variant in product.variants
                        if variant.options[size_option_index] == value
                          assign size_variant = variant
                        endif
                      endfor
                      assign size_in_stock = false
                      if size_variant != nil and size_variant.available
                        assign size_in_stock = true
                      endif
                      assign qty = size_variant.inventory_quantity
                      assign is_low_stock = false
                      if qty > 0 and qty <= 10
                        assign is_low_stock = true
                      endif
                    -%}
                    <button
                      type="button"
                      {% unless size_in_stock %}disabled{% endunless %}
                      class="size-option-btn relative py-3 text-xs font-semibold rounded-xl border transition-all duration-200 {% if option.selected_value == value %}bg-zinc-900 text-white border-zinc-900 shadow-lg scale-[1.03]{% elsif size_in_stock %}bg-white text-zinc-800 border-zinc-200 hover:border-zinc-400{% else %}bg-white text-zinc-300 border-zinc-100 cursor-not-allowed{% endif %}"
                      data-value="{{ value }}"
                      data-qty="{{ qty }}"
                    >
                      {{ value }}
                      {%- if size_in_stock and is_low_stock and option.selected_value != value -%}
                        <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                      {%- endif -%}
                      {%- unless size_in_stock -%}
                        <span class="absolute inset-0 flex items-center justify-center pointer-events-none">
                          <span class="block w-[60%] h-px bg-zinc-200 rotate-45"></span>
                        </span>
                      {%- endunless -%}
                    </button>
                  {%- endfor -%}
                </div>

                <!-- Size guide triggers -->
                <div class="mt-3.5 flex items-center justify-between">
                  <p class="low-stock-legend text-[10px] text-zinc-400 flex items-center gap-1.5 hidden">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></span>
                    Low stock
                  </p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <!-- Size Guide Button (always shown if chart exists) -->
      <!-- DEBUG: key={{ size_chart_key }} blank={{ size_chart_html | blank }} -->
      {%- if size_chart_html != blank -%}
        <div class="mt-2 flex justify-end">
          <button
            type="button"
            class="size-guide-trigger-btn flex items-center gap-1.5 text-xs font-semibold text-zinc-500 hover:text-zinc-800 transition-colors bg-transparent border-0 outline-none"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400">
              <line x1="12" x2="12" y1="5" y2="19"></line>
              <line x1="5" x2="19" y1="12" y2="12"></line>
              <line x1="8" x2="16" y1="16" y2="16"></line>
              <line x1="8" x2="16" y1="8" y2="8"></line>
            </svg>
            <span>Size Guide</span>
          </button>
        </div>
      {%- endif -%}

      <!-- ACCORDION SECTIONS -->
      <div class="product-accordions-group mt-4 border-t border-zinc-100">
        
        <!-- Accordion 1: Attention Seekers -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Attention style seekers</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc whitespace-pre-line">
            {%- if product.metafields.custom.attention_seekers != blank -%}
              {{ product.metafields.custom.attention_seekers }}
            {%- else -%}
              {% case product.handle %}
                {% when 'oversized-dual-tone-sweatshirt' %}
                  <p>Blue and orange, bold and bright, get ready to stand out!</p>
                {% when 'oversized-sweatshirt-turtleneck' %}
                  <p>Slip me on, and let comfort lead the way!</p>
                {% when 'overlap-neck-sweatshirt' %}
                  <p>You want your wardrobe to level up, try this soft scuba sweatshirt</p>
                {% when 'crewneck-oversized-sweatshirt' %}
                  <p>Grab this piece, and let your style do the talking </p>
                {% when 'hoodie-with-burgundy-piping' %}
                  <p>For comfort and boldness in one, this hoodie has you covered</p>
                {% when 'hoodie-with-leather-piped-detailing' %}
                  <p>This hoodie doesn't follow trend, it sets them </p>
                {% when 'all-in-well-hoodie' %}
                  <p>Take the lead, wear the vibe</p>
                {% when 'apricity-leather-patch-hoodie' %}
                  <p>Own the Look in Brown</p>
                {% when 'double-collar-cropped-sweatshirt' %}
                  <p>Own the spotlight with a sweatshirt as bold as you are</p>
                {% when 'a-new-era-cropped-sweatshirt' %}
                  <p>Be the change. Be the era. Wear it like you mean it</p>
                {% when 'indulge-in-self-love-hoodie' %}
                  <p>Dare to be different. Own the look. Own the moment</p>
                {% when '3d-apricity-hoodie' %}
                  <p>Own your look, own your day, Midnight Navy never fails</p>
                {% when 'bayview-linen-set' %}
                  <p>Light linen, heavy presence. Walk freely and let Bay View BLVD. make the world notice you</p>
                {% when 'club-1932-t-shirt' %}
                  <p>Carrying the emblem of our homeland in our hearts, we walk boldly, proudly, and endlessly Saudi</p>
                {% when 'onyx-black' %}
                  <p>Strong and silent, they never chase attention, ONYX is the power they wear</p>
                {% when 'onyx-gray' %}
                  <p>Strong and silent, they never chase attention, ONYX is the power they wear</p>
                {% when 'echoes-of-silence-green' %}
                  <p>A perfect blend of power, style, and confidence for anyone who isn't afraid to be noticed</p>
                {% when 'echoes-of-silence-white' %}
                  <p>A perfect blend of power, style, and confidence for anyone who isn't afraid to be noticed</p>
                {% when 'staple-sand' %}
                  <p>Where minimal meets meaning</p>
                {% when 'apricity-blush' %}
                  <p>Soft enough to blush. Bold enough to own it</p>
                {% when 'apy-butter-set' %}
                  <p>Soft like butter. Sharp like attitude</p>
                {% else %}
                  {{ settings.default_attention_seekers }}
              {% endcase %}
            {%- endif -%}
          </div>
        </div>

        <!-- Accordion 2: Description & Features -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Description & Features</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc">
            {%- if product.metafields.custom.description != blank -%}
              {{ product.metafields.custom.description }}
            {%- elsif product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              {% case product.handle %}
                {% when 'oversized-dual-tone-sweatshirt' %}
                  <p>Brighten up your wardrobe with this eye-catching sweatshirt. The rich blue base is complemented by vibrant orange accents on the neckline and cuffs, giving it a sporty, dynamic feel. A fun and energetic addition to your style!</p><ul><li>Color : Cobalt Blue </li><li>Material: Soft Scuba & Cotton Blend – smooth, breathable</li><li>Bold 3D embossed text – Apricity is like a warm affection that wraps around your soul – bringing an inspiring message to life in striking texture.</li><li>Back 3D embossed 'APRICITY'</li><li>Double Collar Neck & Cuffs</li></ul>
                {% when 'oversized-sweatshirt-turtleneck' %}
                  <p>This cozy and stylish, uniquely gray sweatshirt is a must-have for you! Made from soft, high-quality fabric, it offers warmth and comfort. Featuring unique neck details and thumb holes for added flair, its combination of style and coziness is unmatched</p><ul><li>Color: Charcoal Gray </li><li>Material: A premium blend of fleece, cotton, and polyester, offering ultimate warmth softness</li><li>Embroidery logo on the turtleneck for a stylish touch</li><li>Back embroidery of 'APRICITY' </li><li>Two-tone grey cuffs, featuring a lighter grey accent at the thumb hole</li></ul>
                {% when 'overlap-neck-sweatshirt' %}
                  <p>This soft black sweatshirt boasts stylish elbow line details and bold blue overlapping neck accents for a modern edge. Its clean black base and unique design make it a must-have for those who value fashion-forward yet comfortable pieces.</p><ul><li>Color : Black</li><li>Material : Soft Scuba & Cotton Blend – smooth, breathable</li><li>Two-tone overlapping neck for a modern, stylish look</li><li>Front leather patch logo</li><li>Back 3D embossed logo </li><li>Around elbow line details</li></ul>
                {% when 'crewneck-oversized-sweatshirt' %}
                  <p>Step up your style game with the Apricity Chili Red Sweatshirt. This statement piece features a bold black logo on the back that's sure to turn heads. Perfect for those who aren't afraid to be noticed, this sweatshirt combines comfort, quality, and a daring style that says "look at me"</p><ul><li>Color : Chili Red</li><li>Material : Soft Scuba & Cotton Blend – smooth, breathable</li><li>Debossed 'APRICITY'on the turtleneck for a stylish touch</li><li>Back embroidery 'APRICITY'</li><li>Front embroidery Text – shine so brightly that others can't escape the warmth of your presence –</li></ul>
                {% when 'hoodie-with-burgundy-piping' %}
                  <p>This brown hoodie redefines casual wear with a refined design. It features a textured look, a leather patch on the front, and double-line details in brown and burgundy, complemented by a burgundy inner pocket. Unique line details around the hood add a sharp, dynamic touch</p><ul><li>Color : Coffee Brown</li><li>Material : Soft Scuba & Cotton Blend – smooth, breathable</li><li>Front leather patch 'APRICITY'</li><li>Double-line details in brown and burgundy on the shoulders and hood create a modern, refined look</li><li>Burgundy inner pocket</li></ul>
                {% when 'hoodie-with-leather-piped-detailing' %}
                  <p>Black hoodie from Apricity brings together luxury and edge. The embossed leather logo patch on the front exudes sophistication, while the metal leather patch and sleek leather piping add a modern, industrial twist. Crafted for ultimate comfort, this hoodie is designed for those who demand style with substance</p><ul><li>Color : Black</li><li>Material : Soft Scuba & Cotton Blend – smooth, breathable</li><li>Bold, large leather patch with 'APRICITY' on the front for a standout look</li><li>Leather line details on the shoulders, hood and back </li><li>Back leather metal patch 'APRICITY'</li></ul>
                {% when 'all-in-well-hoodie' %}
                  <p>This ivory cream hoodie blends elegance and trendiness with subtle blue details for a twist. The soft cream fabric provides a cozy base, while the blue accents offer a stylish contrast, making it a standout and versatile piece for any casual outfit</p><ul><li>Color: Ivory Cream</li><li>Material: A premium blend of fleece, cotton, and polyester, offering ultimate warmth softness</li><li>Vibrant blue inner neck layer, adding a bold, refreshing contrast</li><li>Embroidery 'All in well' </li><li>Cuff patch text – Apricity (n.) The warmth of the sun in the winter –</li><li>Under the hood Embroidery 'APRICITY' </li></ul>
                {% when 'apricity-leather-patch-hoodie' %}
                  <p>The Brown Hoodie That Speaks Volumes—crafted in rich brown, featuring a leather patch and the Apricity logo on the back. Soft, comfortable, and full of unique details, it's the perfect blend of luxury and style.</p><ul><li>Color: Coffee Brown</li><li>Material: A premium blend of fleece, cotton, and polyester, offering ultimate warmth softness</li><li>Bold, large leather patch with text – Apricity (n.) The warmth of the sun in the winter – </li><li>Back embroidery 'APRICITY' </li></ul>
                {% when 'double-collar-cropped-sweatshirt' %}
                  <p>Get ready to make a statement! This Ivory Cream Cropped Sweatshirt with a bold Green Double collar is designed for the trendsetter in you. With its fresh, eye-catching color combination, this piece brings comfort and style together effortlessly</p><ul><li>Color: Ivory Cream</li><li>Material: A premium blend of fleece, cotton, and polyester, offering ultimate warmth softness</li><li>Front embroidery 'APRICITY' </li><li>shoulder double pocket—one with a sleek zipper, and one open for easy access. Perfect for storing your lipstick while hanging out!</li><li>Double collar featuring green accents</li></ul>
                {% when 'a-new-era-cropped-sweatshirt' %}
                  <p>Bring a fresh vibe to your look with this cropped sweatshirt. The soft sky blue tone pairs with bold embroidery details, making it the perfect mix of comfort and statement style. A new era, your way.</p><ul><li>Color: Sky Blue</li><li>Material: Material: Blend of french terry and cotton, for ultimate comfort </li><li>Front embroidery 'APRICITY' </li><li>Back embroidery text – A New Era of Me –</li></ul>
                {% when 'indulge-in-self-love-hoodie' %}
                  <p>Stay cozy and stylish in our Blissful Blue hoodie, designed for comfort and a contemporary aesthetic. Combining urban edge with premium craftsmanship, it offers an elevated look that's impossible to miss! Thumbhole cuffs add a touch of flair, while the leather patch on the pocket and hood adds a refined, high-end feel</p><ul><li>Color: Blissful Blue</li><li>Material: A premium blend of fleece, cotton, and polyester, offering ultimate warmth softness</li><li>Front embroidery logo</li><li>Front pocket leather patch 'APRICITY' </li><li>two-tone cuffs with a cream accent at the thumb hole for added style</li><li>leather and embroidered logos on the hood add standout style</li><li>Back embroidery text – Indulge in Selflove –</li></ul>
                {% when '3d-apricity-hoodie' %}
                  <p>Discover effortless style with our Midnight Navy Hoodie. Crafted in rich navy, it combines comfort and sophistication, with subtle embossed branding and a dark purple hood lining for a unique pop of color an essential wardrobe addition</p><ul><li>Color : Midnight Navy</li><li>Material : Soft Scuba & Cotton Blend – smooth, breathable</li><li>Front embossed 'APRICITY'</li><li>Two-tone cuffs with a dark purple accent at the thumb hole for added style</li><li>Bold, large text embossed with 'APRICITY' on the back for a standout look</li><li>Vibrant purple inner hood</li></ul>
                {% when 'bayview-linen-set' %}
                  <p>A breezy buttercream linen set featuring a relaxed-fit shirt with an embroidered sketch of a surfer holding a board, paired with matching comfy shorts. Perfect for sunny days, beach strolls, or chilled weekends</p><ul><li>Color: Buttercream</li><li>Material: Premium Poly Linen Orbit, lightweight, breathable</li><li>Front Print: embroidery of a minimalist surfer figure holding a board, adding a playful, artistic</li><li>Back Print: Printed text on the back: "the summer nights when everything comes alive – by APY" Evoking the magic and energy of summer evenings</li><li>Bottoms Design: Coordinated shorts with an elastic waistband for ease and comfort. Finished with the distinctive APRICITY logo, adding a touch of signature style</li></ul>
                {% when 'club-1932-t-shirt' %}
