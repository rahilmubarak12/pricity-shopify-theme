{% comment %}
  Product Detail Snippet
  Shared code for both main-product.liquid section and templates/product.quickview.liquid.
  Accepts:
  - product: {Product} Shopify product object
  - is_modal: {Boolean} true if rendered inside the quickview modal
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign images = product.images
  assign featured_image = current_variant.featured_image | default: product.featured_image

  assign is_out_of_stock = true
  if product.available
    assign is_out_of_stock = false
  endif

  # Calculate discounts
  assign is_on_sale = false
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  if compare_at_price > price
    assign is_on_sale = true
  endif

  # Select size chart fallback based on product type
  assign product_type_lower = product.type | downcase
  assign size_chart_title = 'Unisex Size Chart'
  assign size_chart_html = ''

  if product_type_lower contains 'hoodie'
    assign size_chart_title = 'Unisex Hoodies Size Chart'
    assign size_chart_html = '<table width="100%"><tbody><tr><td></td><td style="text-align: center;">Length</td><td style="text-align: center;">Sleeve</td><td style="text-align: center;">1/2 Chest</td><td style="text-align: center;">Shoulder</td></tr><tr style="text-align: center;"><td>S/M</td><td>69</td><td>54-56</td><td>62-63</td><td>65-67</td></tr><tr style="text-align: center;"><td>M/L</td><td>71</td><td>57-58</td><td>64-66</td><td>68-69</td></tr><tr style="text-align: center;"><td>L/XL</td><td>73</td><td>59</td><td>67-69</td><td>70-74</td></tr></tbody></table>'
  elsif product_type_lower contains 't-shirt' or product_type_lower contains 'top' or product_type_lower contains 'tee'
    assign size_chart_title = 'Unisex T-Shirt Size Chart'
    assign size_chart_html = '<table width="100%"><tbody><tr><td></td><td style="text-align: center;">Length</td><td style="text-align: center;">Sleeve</td><td style="text-align: center;">Chest</td><td style="text-align: center;">Shoulder</td></tr><tr style="text-align: center;"><td>S/M</td><td>70</td><td>23</td><td>55</td><td>48</td></tr><tr style="text-align: center;"><td>M/L</td><td>75</td><td>25.5</td><td>60</td><td>50</td></tr><tr style="text-align: center;"><td>L/XL</td><td>78</td><td>26.5</td><td>62</td><td>53</td></tr></tbody></table>'
  elsif product_type_lower contains 'set' or product_type_lower contains 'linen'
    assign size_chart_title = 'Linen Shirt & Shorts Size Chart'
    assign size_chart_html = '<table width="100%"><tbody><tr><td></td><td style="text-align: center;">Waist (elastic)</td><td style="text-align: center;">Shorts Length</td><td style="text-align: center;">Shirt Length</td><td style="text-align: center;">Chest</td><td style="text-align: center;">Shoulder</td></tr><tr style="text-align: center;"><td>S/M</td><td>33</td><td>43</td><td>64</td><td>51</td><td>46</td></tr><tr style="text-align: center;"><td>M/L</td><td>37</td><td>48</td><td>67</td><td>54</td><td>48</td></tr><tr style="text-align: center;"><td>L/XL</td><td>43</td><td>50</td><td>70</td><td>57</td><td>50</td></tr></tbody></table>'
  else
    # Default to sweatshirt size chart
    assign size_chart_title = 'Unisex Sweatshirts Size Chart'
    assign size_chart_html = '<table width="100%"><tbody><tr><td></td><td style="text-align: center;">Length</td><td style="text-align: center;">Sleeve</td><td style="text-align: center;">1/2 Chest</td><td style="text-align: center;">Shoulder</td></tr><tr style="text-align: center;"><td>S/M</td><td>69-70</td><td>54</td><td>66-67</td><td>68</td></tr><tr style="text-align: center;"><td>M/L</td><td>71-72</td><td>55-56</td><td>68-69</td><td>69-70</td></tr><tr style="text-align: center;"><td>L/XL</td><td>73</td><td>57</td><td>70</td><td>71</td></tr></tbody></table>'
  endif
-%}

<div class="product-detail-wrapper flex flex-col lg:flex-row w-full h-full" data-product-handle="{{ product.handle }}">
  
  <!-- LEFT COLUMN: Image Gallery -->
  <div class="w-full lg:w-1/2 bg-zinc-50 p-6 flex flex-col gap-3 lg:overflow-y-auto" style="-webkit-overflow-scrolling: touch;">
    <div class="w-full bg-white rounded-2xl overflow-hidden relative">
      <img 
        src="{{ featured_image | image_url: width: 1000 }}" 
        alt="{{ product.title | escape }}" 
        class="product-main-image w-full h-auto object-contain transition-transform duration-700 ease-out hover:scale-110 cursor-zoom-in"
       width="1000" height="1000" />
    </div>
    {%- if images.size > 1 -%}
      <div class="flex gap-2 overflow-x-auto pb-1 product-thumbnails">
        {%- for img in images -%}
          <button
            type="button"
            class="thumbnail-btn flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 transition {% if featured_image == img %}border-black{% else %}border-transparent{% endif %}"
            data-image-url="{{ img | image_url: width: 1000 }}"
          >
            <img src="{{ img | image_url: width: 150 }}" alt="" class="w-full h-full object-cover"  width="1000" height="1000" />
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- RIGHT COLUMN: Details & Option Pickers -->
  <div class="w-full lg:w-1/2 flex flex-col lg:overflow-hidden bg-white">
    <!-- Scrollable Panel -->
    <div class="flex-1 lg:overflow-y-auto px-8 py-10 gap-6 flex flex-col" style="-webkit-overflow-scrolling: touch;">
      
      <!-- Title & Price -->
      <div class="flex flex-col gap-2">
        <h2 class="text-2xl font-bold uppercase leading-tight tracking-tight text-[#1a1a1a]">
          {{ product.title }}
        </h2>
        <div class="flex items-baseline gap-3">
          <span class="product-price-display text-2xl font-semibold tracking-tight text-zinc-900">
            {{ price | money_without_trailing_zeros }}
          </span>
          <span class="product-compare-display text-sm text-zinc-400 line-through {% unless is_on_sale %}hidden{% endunless %}">
            {{ compare_at_price | money_without_trailing_zeros }}
          </span>
        </div>
      </div>

      <!-- Option Selectors -->
      {%- unless product.has_only_default_variant -%}
        <div class="product-options-picker space-y-6">
          {%- for option in product.options_with_values -%}
            {%- assign option_name_lower = option.name | downcase -%}
            
            {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
              <!-- Color Selector -->
              <div class="option-color-container" data-option-index="{{ forloop.index0 }}">
                <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 mb-3 font-medium">
                  Colour — <span class="active-color-label text-zinc-600 normal-case tracking-normal">{{ option.selected_value }}</span>
                </p>
                <div class="flex flex-wrap gap-2">
                  {%- for value in option.values -%}
                    {%- liquid
                      # Simple color verification to see if at least one variant of this color is in stock
                      assign color_in_stock = false
                      for variant in product.variants
                        if variant.options[forloop.parentloop.index0] == value and variant.available
                          assign color_in_stock = true
                        endif
                      endfor
                    -%}
                    <button
                      type="button"
                      class="color-option-btn px-4 py-2 text-xs rounded-full border transition-all duration-200 tracking-wide {% if option.selected_value == value %}bg-zinc-900 text-white border-zinc-900 shadow-md{% else %}bg-white text-zinc-700 border-zinc-200 hover:border-zinc-500{% endif %} {% unless color_in_stock %}opacity-35 line-through{% endunless %}"
                      data-value="{{ value }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>

            {%- elsif option_name_lower == 'size' or option_name_lower == 'sizes' -%}
              <!-- Size Selector -->
              <div class="option-size-container rounded-2xl border border-zinc-100 bg-zinc-50/80 p-5" data-option-index="{{ forloop.index0 }}">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-medium">
                    Select Size
                  </span>
                  
                  <!-- Live Stock Message (amber dots/critical alerts) -->
                  <span class="stock-status-indicator text-[10px] font-semibold tracking-wide uppercase flex items-center gap-1.5 text-emerald-600">
                    <!-- Updated by JS -->
                    In Stock
                  </span>
                </div>

                <div class="grid grid-cols-4 gap-2">
                  {%- for value in option.values -%}
                    {%- liquid
                      # Check if this size is available
                      assign size_variant = nil
                      for variant in product.variants
                        if variant.options[forloop.parentloop.index0] == value
                          assign size_variant = variant
                        endif
                      endfor
                      assign size_in_stock = false
                      if size_variant != nil and size_variant.available
                        assign size_in_stock = true
                      endif
                      assign qty = size_variant.inventory_quantity
                      assign is_low_stock = false
                      if qty > 0 and qty <= 10
                        assign is_low_stock = true
                      endif
                    -%}
                    <button
                      type="button"
                      {% unless size_in_stock %}disabled{% endunless %}
                      class="size-option-btn relative py-3 text-xs font-semibold rounded-xl border transition-all duration-200 {% if option.selected_value == value %}bg-zinc-900 text-white border-zinc-900 shadow-lg scale-[1.03]{% elsif size_in_stock %}bg-white text-zinc-800 border-zinc-200 hover:border-zinc-400{% else %}bg-white text-zinc-300 border-zinc-100 cursor-not-allowed{% endif %}"
                      data-value="{{ value }}"
                      data-qty="{{ qty }}"
                    >
                      {{ value }}
                      {%- if size_in_stock and is_low_stock and option.selected_value != value -%}
                        <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                      {%- endif -%}
                      {%- unless size_in_stock -%}
                        <span class="absolute inset-0 flex items-center justify-center pointer-events-none">
                          <span class="block w-[60%] h-px bg-zinc-200 rotate-45"></span>
                        </span>
                      {%- endunless -%}
                    </button>
                  {%- endfor -%}
                </div>

                <!-- Size guide triggers -->
                <div class="mt-3.5 flex items-center justify-between">
                  <p class="low-stock-legend text-[10px] text-zinc-400 flex items-center gap-1.5 hidden">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></span>
                    Low stock
                  </p>
                  
                  {%- if size_chart_html != blank -%}
                    <button
                      type="button"
                      class="size-guide-trigger-btn flex items-center gap-1.5 text-xs font-semibold text-zinc-500 hover:text-zinc-800 transition-colors bg-transparent border-0 outline-none"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400">
                        <line x1="12" x2="12" y1="5" y2="19"></line>
                        <line x1="5" x2="19" y1="12" y2="12"></line>
                        <line x1="8" x2="16" y1="16" y2="16"></line>
                        <line x1="8" x2="16" y1="8" y2="8"></line>
                      </svg>
                      <span>Size Guide</span>
                    </button>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <!-- ACCORDION SECTIONS -->
      <div class="product-accordions-group mt-4 border-t border-zinc-100">
        
        <!-- Accordion 1: Attention Seekers -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Attention style seekers</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc whitespace-pre-line">
            {%- if product.metafields.custom.attention_seekers != blank -%}
              {{ product.metafields.custom.attention_seekers }}
            {%- else -%}
              Designed for those who move between worlds — from quiet confidence to bold statements. Apricity Officials speaks to the individual who appreciates quality without compromise. This piece is made for you.
            {%- endif -%}
          </div>
        </div>

        <!-- Accordion 2: Description & Features -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Description & Features</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc">
            {{ product.description }}
          </div>
        </div>

        <!-- Accordion 3: Size & Fit -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Size & Fit</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc">
            {%- if product.metafields.custom.size_fit != blank -%}
              {{ product.metafields.custom.size_fit }}
            {%- else -%}
              Designed for a versatile unisex fit, it looks great on everyone.
              <p class="text-xs text-zinc-400 mt-2">Recommended: Go for your normal size for a relaxed standard fit, or size up for an oversized streetwear look.</p>
            {%- endif -%}
          </div>
        </div>

        <!-- Accordion 4: Take Care of Me -->
        <div class="border-b border-zinc-100 accordion-item">
          <button type="button" class="accordion-header w-full flex items-center justify-between py-4 text-left group">
            <div class="flex items-center gap-3">
              <img src="{{ 'logo.png' | asset_url }}" alt="" class="h-4 w-4 object-contain opacity-40"  width="1000" height="1000" />
              <span class="text-sm text-zinc-700 font-medium tracking-wide">Take care of me</span>
            </div>
            <span class="accordion-plus text-zinc-400 text-xl transition-transform duration-300">+</span>
          </button>
          <div class="accordion-body hidden pb-5 px-1 text-sm text-zinc-500 leading-relaxed prose prose-sm max-w-none prose-zinc">
            {%- if product.metafields.custom.care_instructions != blank -%}
              {{ product.metafields.custom.care_instructions }}
            {%- else -%}
              <ul class="space-y-1.5">
                <li class="text-xs text-zinc-400 flex items-start gap-2"><span class="mt-0.5 shrink-0">·</span>Machine wash cold at 30°C, inside out</li>
                <li class="text-xs text-zinc-400 flex items-start gap-2"><span class="mt-0.5 shrink-0">·</span>Do not tumble dry — hang to dry</li>
                <li class="text-xs text-zinc-400 flex items-start gap-2"><span class="mt-0.5 shrink-0">·</span>Iron on low heat, inside out only</li>
                <li class="text-xs text-zinc-400 flex items-start gap-2"><span class="mt-0.5 shrink-0">·</span>Do not bleach</li>
                <li class="text-xs text-zinc-400 flex items-start gap-2"><span class="mt-0.5 shrink-0">·</span>Store folded to preserve shape</li>
              </ul>
            {%- endif -%}
          </div>
        </div>

      </div>

    </div>

    <!-- STICKY CTA BUTTONS FOOTER -->
    <div class="flex-shrink-0 border-t border-zinc-100 bg-white px-6 py-4 flex flex-col gap-3">
      <div class="flex items-center justify-center text-[10px] text-zinc-400 tracking-wide uppercase">
        <span>Secure checkout</span>
      </div>

      <!-- Quantity Selector -->
      <div class="product-qty-row flex items-center justify-between border border-zinc-200 bg-white rounded-xl h-12 w-full px-4">
        <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Quantity</span>
        <div class="flex items-center gap-4">
          <button
            type="button"
            class="product-qty-btn-minus w-8 h-8 flex items-center justify-center text-zinc-400 hover:text-zinc-950 disabled:opacity-30 transition-colors rounded-full hover:bg-zinc-50"
            aria-label="Decrease quantity"
            disabled
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" x2="19" y1="12" y2="12"></line>
            </svg>
          </button>
          
          <span class="product-qty-display-value font-mono-street text-sm text-zinc-950 font-bold min-w-[1.5rem] text-center">1</span>
          
          <button
            type="button"
            class="product-qty-btn-plus w-8 h-8 flex items-center justify-center text-zinc-400 hover:text-zinc-950 disabled:opacity-30 transition-colors rounded-full hover:bg-zinc-50"
            aria-label="Increase quantity"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" x2="12" y1="5" y2="19"></line>
              <line x1="5" x2="19" y1="12" y2="12"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Buy buttons -->
      <div class="flex gap-2.5">
        <button
          type="button"
          class="product-add-to-cart flex-1 py-4 rounded-xl text-sm font-semibold tracking-[0.1em] uppercase flex items-center justify-center gap-2.5 transition-all duration-300 bg-zinc-900 text-white hover:bg-zinc-700 shadow-lg shadow-zinc-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="btn-text">Add to Cart</span>
        </button>

        <button
          type="button"
          class="product-quick-buy flex-1 py-4 rounded-xl text-sm font-semibold tracking-[0.1em] uppercase flex items-center justify-center gap-2.5 transition-all duration-300 bg-white text-zinc-900 border border-zinc-300 hover:border-zinc-900 hover:bg-zinc-50 shadow-sm"
        >
          Quick Buy
        </button>
      </div>
    </div>

  </div>

  <!-- Size Chart Sub-Modal -->
  {%- if size_chart_html != blank -%}
    <div
      class="product-size-chart-modal hidden fixed inset-0 z-[99999] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
    >
      <div
        class="bg-white w-full max-w-2xl rounded-2xl p-6 md:p-8 shadow-2xl flex flex-col relative max-h-[85vh] overflow-hidden"
      >
        <!-- Header -->
        <div class="flex items-center justify-between pb-4 border-b border-zinc-100 mb-6">
          <div class="flex items-center gap-2.5 text-zinc-900 font-semibold tracking-wide uppercase">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" x2="12" y1="5" y2="19"></line>
              <line x1="5" x2="19" y1="12" y2="12"></line>
              <line x1="8" x2="16" y1="16" y2="16"></line>
              <line x1="8" x2="16" y1="8" y2="8"></line>
            </svg>
            <h3 class="text-sm font-semibold text-zinc-900 tracking-wide uppercase">
              {{ size_chart_title }}
            </h3>
          </div>
          <button
            type="button"
            class="size-chart-modal-close p-1.5 rounded-full text-zinc-400 hover:text-zinc-600 hover:bg-zinc-100 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" x2="6" y1="6" y2="18"></line>
              <line x1="6" x2="18" y1="6" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Chart content -->
        <div class="overflow-x-auto overflow-y-auto pr-2 flex-grow">
          <div class="size-chart-table text-sm text-zinc-600 prose prose-sm max-w-none prose-zinc">
            {{ size_chart_html }}
          </div>
        </div>

        <!-- Footer -->
        <div class="mt-6 pt-4 border-t border-zinc-100 text-[10px] text-zinc-400 flex items-center justify-center">
          <span>All measurements are in centimeters (cm) unless specified otherwise.</span>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Product JSON for Variant Checking Script -->
  <script type="application/json" class="product-raw-json">
    {
      "id": "{{ product.id }}",
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": "{{ variant.id }}",
            "title": "{{ variant.title | escape }}",
            "options": {{ variant.options | json }},
            "available": {{ variant.available | json }},
            "inventory_quantity": {{ variant.inventory_quantity | default: 99 }},
            "price": "{{ variant.price | money_without_trailing_zeros }}",
            "price_raw": {{ variant.price }},
            "compare_at_price": "{{ variant.compare_at_price | money_without_trailing_zeros }}",
            "featured_image": {% if variant.featured_image != blank %}"{{ variant.featured_image | image_url: width: 1000 }}"{% else %}null{% endif %}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "options": {{ product.options | json }}
    }
  </script>
</div>
