[
  {
    "name": "theme_info",
    "theme_name": "Apricity Custom Theme",
    "theme_version": "1.0.0",
    "theme_author": "Antigravity",
    "theme_documentation_url": "https://github.com/",
    "theme_support_url": "https://github.com/"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary (Text, Buttons, etc.)",
        "default": "#141414"
      },
      {
        "type": "color",
        "id": "color_contrast",
        "label": "Contrast (Backgrounds, Borders, etc.)",
        "default": "#fafaf9"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Labels like On Sale)",
        "default": "#bf4800"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Base Page Background",
        "default": "#faf9f7"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Fallback Heading Font (Shopify Library)",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Fallback Body Font (Shopify Library)",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_size_scale",
        "label": "Body Font Size Scale",
        "min": 80,
        "max": 120,
        "step": 5,
        "unit": "%",
        "default": 100
      },
      {
        "type": "header",
        "content": "Custom Brand Fonts"
      },
      {
        "type": "paragraph",
        "content": "Custom luxury brand fonts are pre-loaded from assets:\n- Dream Avenue (luxury display headings)\n- Jost (standard body text & buttons)\n- Montserrat (street details & tracking)\n- Cormorant (brand wordmark)"
      }
    ]
  },
  {
    "name": "Checkout Layout",
    "settings": [
      {
        "type": "header",
        "content": "Banner"
      },
      {
        "type": "image_picker",
        "id": "checkout_banner_image",
        "label": "Banner Image",
        "info": "Recommended size: 1000 x 400px"
      },
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "checkout_logo_image",
        "label": "Logo Image"
      },
      {
        "type": "select",
        "id": "checkout_logo_position",
        "label": "Logo Position",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ],
        "default": "left"
      },
      {
        "type": "select",
        "id": "checkout_logo_size",
        "label": "Logo Size",
        "options": [
          { "value": "small", "label": "Small" },
          { "value": "medium", "label": "Medium" },
          { "value": "large", "label": "Large" }
        ],
        "default": "medium"
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "checkout_accent_color",
        "label": "Accent Color",
        "default": "#141414"
      },
      {
        "type": "color",
        "id": "checkout_button_color",
        "label": "Button Color",
        "default": "#141414"
      },
      {
        "type": "color",
        "id": "checkout_error_color",
        "label": "Error Color",
        "default": "#ff5c5c"
      }
