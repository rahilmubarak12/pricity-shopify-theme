        "max": 130,
        "step": 5,
        "default": 100,
        "unit": "%"
      }
    ]
  },
  {
    "name": "Product Page",
    "settings": [
      {
        "type": "header",
        "content": "Sticky Add to Cart"
      },
      {
        "type": "checkbox",
        "id": "sticky_atc_enabled",
        "label": "Enable Sticky Add to Cart Bar",
        "default": true
      },
      {
        "type": "header",
        "content": "Trust Badges"
      },
      {
        "type": "checkbox",
        "id": "trust_badges_enabled",
        "label": "Show Trust Badges",
        "default": true
      },
      {
        "type": "text",
        "id": "trust_badge_1_text",
        "label": "Badge 1 Text",
        "default": "Secure Pay"
      },
      {
        "type": "text",
        "id": "trust_badge_2_text",
        "label": "Badge 2 Text",
        "default": "Free Delivery"
      },
      {
        "type": "text",
        "id": "trust_badge_3_text",
        "label": "Badge 3 Text",
        "default": "Easy Returns"
      },
      {
        "type": "text",
        "id": "trust_badge_4_text",
        "label": "Badge 4 Text",
        "default": "Premium"
      },
      {
        "type": "header",
        "content": "Low Stock Warning"
      },
      {
        "type": "range",
        "id": "low_stock_threshold",
        "label": "Show 'Only X left' when stock is at or below",
        "min": 1,
        "max": 10,
        "step": 1,
        "default": 3
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_upsell_enabled",
        "label": "Show Upsell in Cart",
        "default": true
      },
      {
        "type": "text",
        "id": "cart_upsell_title",
        "label": "Upsell Section Title",
        "default": "You May Also Like"
      },
      {
        "type": "collection",
        "id": "cart_upsell_collection",
        "label": "Upsell Products Collection"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_twitter_link",
        "label": "Twitter / X URL"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook URL"
      }
    ]
  },
  {
    "name": "Checkout",
