{% comment %}
  Default Page Template — checks handle for our-story to render custom layout
{% endcomment %}

{% if page.handle == 'our-story' %}
  {% section 'our-story' %}
{% else %}
<div class="shopify-page__container max-w-4xl mx-auto px-6 pt-32 pb-16 md:pt-40 md:pb-24">
  <header class="text-center mb-12 page-header">
    <h1 class="font-heading font-extrabold text-3xl md:text-5xl uppercase tracking-widest text-black">
      {{ page.title }}
    </h1>
  </header>
  <div class="prose prose-zinc mx-auto text-sm md:text-base leading-relaxed text-zinc-800 font-light">
    {{ page.content }}
  </div>
</div>
{% endif %}
