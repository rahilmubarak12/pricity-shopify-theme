    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "info": "Enter your TikTok profile URL"
    },
    {
      "type": "header",
      "content": "Copyright Info"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Name",
      "default": "Apricity Officials"
    },
    {
      "type": "text",
      "id": "designed_text",
      "label": "Design Credits",
      "default": "Designed in Saudi Arabia 🇸🇦"
    }
  ]
}
