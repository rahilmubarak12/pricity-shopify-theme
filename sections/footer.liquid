{% comment %}
  Footer Section
  Dark luxury layout with newsletter form and mobile accordions.
  Triggering sync update.
{% endcomment %}

<footer class="bg-[#1a1a1a] text-white pt-24 pb-16">
  <div class="max-w-7xl mx-auto px-6 md:px-16">

    <!-- Newsletter -->
    <div class="bg-[#242424] border border-zinc-700 p-8 md:p-16 mb-20 font-mono-street text-xs uppercase tracking-wider">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 space-y-2">
          <span class="text-zinc-500 tracking-[0.2em] block">{{ section.settings.newsletter_subtitle }}</span>
          <h3 class="font-heading font-extrabold text-2xl md:text-3xl text-white uppercase leading-tight">
            {{ section.settings.newsletter_title }}
          </h3>
          <p class="text-zinc-400 text-xs font-light max-w-xl normal-case tracking-normal">
            {{ section.settings.newsletter_description }}
          </p>
        </div>

        <div class="lg:col-span-5">
          {%- form 'customer', id: 'FooterNewsletterForm', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="flex flex-col sm:flex-row gap-2">
              <input
                type="email"
                name="contact[email]"
                id="FooterNewsletterEmail"
                required
                placeholder="{{ section.settings.newsletter_placeholder }}"
                value="{{ form.email }}"
                class="bg-[#1a1a1a] border border-zinc-700 px-4 py-4 text-xs font-mono-street text-white outline-none focus:border-zinc-400 w-full placeholder:text-zinc-600 tracking-widest"
                autocorrect="off"
                autocapitalize="off"
              >
              <button
                type="submit"
                class="bg-white text-black font-mono-street text-xs font-extrabold uppercase px-8 py-4 hover:bg-zinc-200 transition-colors shrink-0 flex items-center justify-center gap-2"
                name="commit"
              >
                Notify Me
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" x2="19" y1="12" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="text-[10px] text-green-400 font-mono-street mt-2 uppercase tracking-widest success-message">
                Successfully joined the drops notification list!
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p class="text-[10px] text-red-400 font-mono-street mt-2 uppercase tracking-widest error-message">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </p>
            {%- else -%}
              <p class="text-[10px] text-zinc-600 font-mono-street mt-2 uppercase tracking-widest disclaimer">
                Zero spam. Unsubscribe anytime.
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>

    <!-- Links (Mobile Accordion Support) -->
    <div class="footer-links-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 pb-16 border-b border-zinc-800 font-mono-street text-[11px] uppercase">

      <!-- Column 1 & 2: About Us -->
      <div class="lg:col-span-2 space-y-4 footer-column" data-accordion>
        <span class="font-heading font-extrabold text-xl tracking-[0.25em] text-white flex items-center justify-between accordion-toggle select-none cursor-pointer md:cursor-default">
          {{ section.settings.about_title }}
          <span class="accordion-icon md:hidden block transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </span>
        <div class="text-zinc-400 text-xs font-light leading-relaxed max-w-md normal-case tracking-normal space-y-2 accordion-content hidden md:block">
          {{ section.settings.about_content }}
        </div>
      </div>

      <!-- Column 3: Client Services -->
      <div class="space-y-3 footer-column" data-accordion>
        <span class="text-white font-bold tracking-wider flex items-center justify-between pb-2 border-b border-zinc-800 accordion-toggle select-none cursor-pointer md:cursor-default">
          {{ section.settings.services_title }}
          <span class="accordion-icon md:hidden block transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </span>
        <ul class="space-y-2.5 text-zinc-400 accordion-content hidden md:block pt-2">
          {%- for link in linklists[section.settings.services_menu].links -%}
            <li>
              <a href="{{ link.url }}" class="hover:text-white transition-colors block font-mono-street text-[11px] uppercase no-underline">
                {{ link.title }}
              </a>
            </li>
          {%- else -%}
            <li>
              <a href="/policies/refund-policy" class="hover:text-white transition-colors block font-mono-street text-[11px] uppercase no-underline">
                Refund Policy
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Column 4: Socials -->
      <div class="space-y-3 footer-column" data-accordion>
        <span class="text-white font-bold tracking-wider flex items-center justify-between pb-2 border-b border-zinc-800 accordion-toggle select-none cursor-pointer md:cursor-default">
          Socials
          <span class="accordion-icon md:hidden block transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </span>
        <ul class="space-y-3 text-zinc-400 accordion-content hidden md:block pt-2">
          {%- assign instagram_href = section.settings.instagram_url | default: settings.social_instagram_link | default: 'https://www.instagram.com/theapricity.officials?igsh=MTE1eTltM3ZoNzFqNQ%3D%3D&utm_source=qr' -%}
          {%- if instagram_href != blank -%}
            <li>
              <a
                href="{{ instagram_href }}"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors flex items-center gap-3 group no-underline"
              >
                <div class="w-5 h-5 flex items-center justify-center text-zinc-400 group-hover:text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                </div>
                <span class="group-hover:text-white">Instagram</span>
              </a>
            </li>
          {%- endif -%}
          {%- assign tiktok_href = section.settings.tiktok_url | default: 'https://www.tiktok.com/@theapricity.officials' -%}
          {%- if tiktok_href != blank -%}
            <li>
              <a
                href="{{ tiktok_href }}"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors flex items-center gap-3 group no-underline"
              >
                <div class="w-5 h-5 flex items-center justify-center text-zinc-400 group-hover:text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.525.229a8.175 8.175 0 0 0 .195 1.763c.487 1.95 1.778 3.514 3.551 4.358a8.21 8.21 0 0 0 3.329.743v3.94a12.11 12.11 0 0 1-4.706-1.127 12.197 12.197 0 0 1-2.18-1.424v7.502a5.5 5.5 0 1 1-5.5-5.5c.307 0 .611.026.91.076v3.985a1.49 1.49 0 0 0-.91-.311 1.5 1.5 0 1 0 1.5 1.5V0h3.811c0 .076 0 .153.001.229z"/>
                  </svg>
                </div>
                <span class="group-hover:text-white">TikTok</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-6 text-[10px] font-mono-street text-zinc-500 uppercase tracking-widest">
      <div>© {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: shop.name }}. All Rights Reserved.</div>
      <div>{{ section.settings.designed_text | default: 'Designed in Saudi Arabia 🇸🇦' }}</div>
    </div>

  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Accordions behavior on mobile (screen width < 768px)
    const accordions = document.querySelectorAll('[data-accordion]');
    
    const setupAccordions = () => {
      accordions.forEach(accordion => {
        const toggle = accordion.querySelector('.accordion-toggle');
        const content = accordion.querySelector('.accordion-content');
        const icon = accordion.querySelector('.accordion-icon');
        
        if (toggle && content) {
          // Clone toggle to remove previous event listeners
          const newToggle = toggle.cloneNode(true);
          toggle.parentNode.replaceChild(newToggle, toggle);
          
          newToggle.addEventListener('click', () => {
            if (window.innerWidth >= 768) return; // Ignore on desktop
            
            const isOpen = !content.classList.contains('hidden');
            
            if (isOpen) {
              content.classList.add('hidden');
              const newIcon = newToggle.querySelector('.accordion-icon');
              if (newIcon) newIcon.classList.remove('rotate-180');
            } else {
              content.classList.remove('hidden');
              const newIcon = newToggle.querySelector('.accordion-icon');
              if (newIcon) newIcon.classList.add('rotate-180');
            }
          });
        }
      });
    };

    // Initial setup
    setupAccordions();

    // Handle screen resize, reset visibility of contents
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        accordions.forEach(accordion => {
          const content = accordion.querySelector('.accordion-content');
          const toggle = accordion.querySelector('.accordion-toggle');
          const icon = toggle ? toggle.querySelector('.accordion-icon') : null;
          if (content) {
            if (window.innerWidth >= 768) {
              content.classList.remove('hidden');
            } else {
              content.classList.add('hidden');
              if (icon) icon.classList.remove('rotate-180');
            }
          }
        });
        setupAccordions();
      }, 250);
    });

    // Set initial visibility based on window width
    if (window.innerWidth < 768) {
      accordions.forEach(accordion => {
        const content = accordion.querySelector('.accordion-content');
        if (content) content.classList.add('hidden');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_subtitle",
      "label": "Newsletter Subtitle",
      "default": "Apricity Archive List"
