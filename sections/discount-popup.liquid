{% comment %}
  Discount Popup Section
  Sticky bottom bar triggers a luxury modal showcasing promo codes with clipboard copy functionality.
{% endcomment %}

<div id="DiscountPopupSection" class="discount-popup-section">
  <!-- Sticky Bottom Bar -->
  <div class="discount-sticky-bar fixed bottom-6 left-4 right-20 sm:left-1/2 sm:right-auto sm:-translate-x-1/2 z-[9998] bg-white text-[#1a1a1a] shadow-2xl rounded-2xl py-4 px-6 flex items-center justify-center gap-3 cursor-pointer hover:shadow-xl transition-all sm:w-auto sm:max-w-xs select-none">
    <span class="font-mono-street text-[11px] uppercase tracking-[0.2em] whitespace-nowrap">
      {{ section.settings.sticky_text | default: "Want 15% off? Tap here" }}
    </span>
    <span class="text-base">👀</span>
  </div>

  <!-- Popup Modal Overlay -->
  <div class="discount-modal-overlay hidden fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div class="discount-modal-content relative bg-white w-full max-w-md rounded-2xl shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300">

      <!-- Close Button -->
      <button class="discount-modal-close absolute top-4 right-4 z-10 p-1.5 rounded-full text-zinc-400 hover:text-zinc-700 hover:bg-zinc-100 transition-colors" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" x2="6" y1="6" y2="18"></line>
          <line x1="6" x2="18" y1="6" y2="18"></line>
        </svg>
      </button>

      <!-- Top Black Band -->
      <div class="bg-[#1a1a1a] px-8 py-6 text-center">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 100 }}" alt="Logo" class="h-10 w-10 object-contain mx-auto mb-3 opacity-80" width="1000" height="1000">
        {%- else -%}
          <img src="{{ 'logo.png' | asset_url }}" alt="Logo" class="h-10 w-10 object-contain mx-auto mb-3 opacity-80" onerror="this.style.display='none';" width="1000" height="1000">
        {%- endif -%}
        <p class="font-mono-street text-[10px] tracking-[0.3em] text-zinc-400 uppercase mb-1">
          Welcome to
        </p>
        <h2 class="text-white font-heading font-extrabold text-2xl tracking-[0.2em] uppercase">
          APRICITY
        </h2>
      </div>

      <!-- Main Content -->
      <div class="px-8 py-8 text-center flex flex-col items-center gap-5">

        <!-- Offer 1 -->
        <div class="w-full border border-zinc-100 rounded-xl px-6 py-4 bg-zinc-50">
          <p class="font-heading font-bold text-3xl text-[#1a1a1a] mb-1">
            {{ section.settings.offer_1_title | default: '15% Off' }}
          </p>
          <p class="text-zinc-500 text-sm font-light">
            {{ section.settings.offer_1_description | default: 'when you purchase two or more items' }}
          </p>
        </div>

        <!-- Offer 2 -->
        <div class="w-full border border-zinc-100 rounded-xl px-6 py-4 bg-zinc-50 flex items-center justify-center gap-3">
          <span class="text-2xl">🇸🇦</span>
          <p class="text-zinc-700 text-sm font-light">
            {{ section.settings.offer_2_text | default: 'Free shipping with no minimum order' }}
          </p>
        </div>

        <p class="text-zinc-400 text-xs font-mono-street tracking-wider uppercase leading-relaxed">
          Apply code at checkout
        </p>

        <!-- Code Box -->
        <button class="discount-copy-button w-full border-2 border-dashed border-zinc-300 hover:border-zinc-900 rounded-xl py-4 px-6 transition-all group select-all">
          <span class="discount-code-text font-mono-street font-bold text-xl tracking-[0.3em] text-[#1a1a1a] group-hover:text-zinc-600 transition-colors">
            {{ section.settings.coupon_code | default: 'APY-15' }}
          </span>
          <p class="copy-status-text text-[10px] text-zinc-400 mt-1 font-mono-street tracking-widest uppercase">
            Tap to copy
          </p>
        </button>

        <!-- Action Button -->
        <button class="discount-shop-now w-full bg-[#1a1a1a] text-white font-mono-street text-xs uppercase tracking-[0.2em] py-4 rounded-xl hover:bg-zinc-700 transition-colors">
          Shop Now
        </button>

        <!-- Dismiss Button -->
        <button class="discount-dismiss text-[11px] text-zinc-400 font-mono-street uppercase tracking-widest hover:text-zinc-600 transition-colors">
          No thanks
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('DiscountPopupSection');
    if (!section) return;

    const stickyBar = section.querySelector('.discount-sticky-bar');
    const overlay = section.querySelector('.discount-modal-overlay');
    const content = section.querySelector('.discount-modal-content');
    const closeBtn = section.querySelector('.discount-modal-close');
    const copyBtn = section.querySelector('.discount-copy-button');
    const codeText = section.querySelector('.discount-code-text').textContent.trim();
    const statusText = section.querySelector('.copy-status-text');
    const shopNowBtn = section.querySelector('.discount-shop-now');
    const dismissBtn = section.querySelector('.discount-dismiss');

    // Show modal function
    const openModal = () => {
      overlay.classList.remove('hidden');
      // Force trigger reflow
      overlay.offsetHeight;
      overlay.classList.remove('opacity-0');
      overlay.classList.add('opacity-100');
      content.classList.remove('scale-95');
      content.classList.add('scale-100');
      document.body.classList.add('overflow-hidden');
    };

    // Close modal function
    const closeModal = () => {
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0');
      content.classList.remove('scale-100');
      content.classList.add('scale-95');
      document.body.classList.remove('overflow-hidden');
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300);
    };

    stickyBar.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    shopNowBtn.addEventListener('click', closeModal);
    dismissBtn.addEventListener('click', closeModal);

    // Close on click outside content
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closeModal();
      }
    });

    // Copy to clipboard function
    const showCopied = () => {
      statusText.textContent = '✓ Copied!';
      statusText.classList.remove('text-zinc-400');
      statusText.classList.add('text-green-500');
      
      setTimeout(() => {
        statusText.textContent = 'Tap to copy';
        statusText.classList.remove('text-green-500');
        statusText.classList.add('text-zinc-400');
      }, 2000);
    };

    const fallbackCopy = () => {
      try {
        const el = document.createElement('textarea');
        el.value = codeText;
        el.setAttribute('readonly', '');
        el.style.position = 'absolute';
        el.style.left = '-9999px';
        document.body.appendChild(el);
        const selected = document.getSelection().rangeCount > 0 ? document.getSelection().getRangeAt(0) : false;
        el.select();
        const success = document.execCommand('copy');
        document.body.removeChild(el);
        if (selected) {
          document.getSelection().removeAllRanges();
          document.getSelection().addRange(selected);
        }
        if (success) {
          showCopied();
        } else {
          console.error('Fallback copy command failed');
        }
      } catch (err) {
        console.error('Fallback copy failed: ', err);
      }
    };

    copyBtn.addEventListener('click', () => {
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(codeText).then(showCopied).catch(err => {
          fallbackCopy();
        });
      } else {
        fallbackCopy();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Discount Popup",
  "settings": [
    {
      "type": "text",
      "id": "sticky_text",
      "label": "Sticky Bar Text",
      "default": "Want 15% off? Tap here"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "coupon_code",
      "label": "Coupon Code",
      "default": "APY-15"
    },
    {
      "type": "text",
      "id": "offer_1_title",
      "label": "Offer 1 Title",
      "default": "15% Off"
    },
    {
      "type": "text",
      "id": "offer_1_description",
      "label": "Offer 1 Description",
      "default": "when you purchase two or more items"
    },
    {
      "type": "text",
      "id": "offer_2_text",
      "label": "Offer 2 Details",
      "default": "Free shipping with no minimum order"
    }
  ],
  "presets": [
    {
      "name": "Discount Popup"
    }
  ]
}
{% endschema %}
